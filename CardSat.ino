// ---- LoTW (Logbook of the World) direct upload (REQUIRES a microSD card) ----
// Builds a signed .tq8 from logged satellite QSOs and uploads it to ARRL's
// self-authenticating web service. Byte format + RSA-PKCS1v15-over-SHA1 signing
// validated host-side against ARRL's developer-tq8 spec (docs/proto/lotw/). This
// is an UPLOAD feature, not enrollment (first-time cert issuance is gated by ARRL
// behind TQSL + a mailed postcard); the user exports their credential to SD once.
#define LOTW_KEY_PEM   "/CardSat/lotw_key.pem"
#define LOTW_CERT_PEM  "/CardSat/lotw_cert.pem"
#define LOTW_TQ8_OUT   "/CardSat/lotw_upload.tq8"

